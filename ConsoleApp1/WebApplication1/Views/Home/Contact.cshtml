@{
    ViewData["Title"] = "Contact";
    // Siguradong may laman, kahit wala sa ViewData ay maglalagay ng default
    string email = ViewData["Email"]?.ToString() ?? "mjudielmeguie@gmail.com";
    string phone = ViewData["Phone"]?.ToString() ?? "+63 943 123 4567";
    string location = ViewData["Location"]?.ToString() ?? "Philippines";
    string github = ViewData["GitHub"]?.ToString() ?? "mjudielmeguiel";
}

<div class="container py-4">
    <h2 class="mb-4">Contact Me</h2>

    <div class="card shadow-sm">
        <div class="card-body p-4">
            <ul class="list-group list-group-flush fs-5">
                <!-- Email -->
                <li class="list-group-item d-flex align-items-center py-3">
                    <i class="bi bi-envelope me-3 text-primary fs-5"></i>
                    <span>@email</span>
                </li>
                <!-- Phone -->
                <li class="list-group-item d-flex align-items-center py-3">
                    <i class="bi bi-phone me-3 text-primary fs-5"></i>
                    <span>@phone</span>
                </li>
                <!-- Location -->
                <li class="list-group-item d-flex align-items-center py-3">
                    <i class="bi bi-geo-alt me-3 text-primary fs-5"></i>
                    <span>@location</span>
                </li>
                <!-- GitHub -->
                <li class="list-group-item d-flex align-items-center py-3">
                    <i class="bi bi-github me-3 text-primary fs-5"></i>
                    <a href="@github" target="_blank" class="text-decoration-none">@github</a>
                </li>
            </ul>

            <a href="mailto:@email" class="btn btn-dark w-100 mt-4">Send Email</a>
        </div>
    </div>
</div>
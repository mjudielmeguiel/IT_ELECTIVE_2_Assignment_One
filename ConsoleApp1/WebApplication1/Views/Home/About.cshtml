@{
    ViewData["Title"] = "About Me";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <h2 class="mb-4">About Me</h2>
        <p class="fs-5 lh-lg text-muted">@ViewData["Bio"]</p>

        <div class="card shadow-sm mt-4">
            <div class="card-body">
                <h5 class="card-title">Education</h5>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item"><strong>Course:</strong> @ViewData["Course"]</li>
                    <li class="list-group-item"><strong>School:</strong> @ViewData["School"]</li>
                    <li class="list-group-item"><strong>Year:</strong> @ViewData["YearLevel"]</li>
                </ul>
            </div>
        </div>
    </div>
</div>
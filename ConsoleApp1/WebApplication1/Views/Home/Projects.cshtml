@{
    ViewData["My Portfolio"] = "Projects";
    var projects = ViewData["ProjectList"] as dynamic[] ?? Array.Empty<dynamic>();
}

<section class="py-4">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold">My Projects</h1>
        <p class="lead text-muted">Here are some of the projects I built during my studies.</p>
    </div>

    <div class="row g-4">
        @foreach (var project in projects)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card shadow h-100">
                    <img src="@project.Image" class="card-img-top" alt="@project.Title" style="height: 200px; object-fit: cover;">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@project.Title</h5>
                        <p class="card-text text-muted">@project.Description</p>
                        <p><strong>Technologies:</strong> @project.Technologies</p>
                    </div>
                </div>
            </div>
        }
    </div>
</section>
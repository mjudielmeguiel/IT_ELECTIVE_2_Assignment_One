@model SkillsViewModel

@{
    ViewData["Title"] = "Skills";
}

<section class="py-5">
    <div class="container">

        <h1 class="fw-bold mb-4">My Skills</h1>

        <div class="row g-4">

            <div class="col-md-6">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h4>Programming Languages</h4>
                        <p>VB.NET, C#, JavaScript, SQL</p>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h4>Web Technologies</h4>
                        <p>HTML, CSS, Bootstrap, ASP.NET Core MVC</p>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h4>Databases</h4>
                        <p>Microsoft Access, SQL Server</p>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h4>Development Tools</h4>
                        <p>Visual Studio, SQL Server Management Studio, GitHub</p>
                    </div>
                </div>
            </div>

        </div>

    </div>
</section>

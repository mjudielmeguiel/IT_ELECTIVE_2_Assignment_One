@model HomeViewModel

@{
    ViewData["Judiel Meguiel Mescallado"] = "Home";
}

<!-- HOME SECTION -->
<section id="home" class="mb-5 py-4">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-5 text-center">
                <img src="@Model.ProfileImageUrl" class="img-fluid rounded shadow" alt="Profile" style="max-width: 300px;">
            </div>
            <div class="col-lg-7">
                <h1 class="display-5 fw-bold">@Model.FullName</h1>
                <h3 class="text-primary mb-3">@Model.Title</h3>
                <p class="lead mb-4">
                    @Model.Bio
                </p>
                <div class="d-flex gap-3">
                    <a href="@Url.Action("Index", "Projects")" class="btn btn-primary">
                        <i class="bi bi-folder-fill me-2"></i>View Projects
                    </a>
                    <a href="@Url.Action("Index", "Contact")" class="btn btn-outline-primary">
                        <i class="bi bi-envelope me-2"></i>Contact Me
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ABOUT ME SECTION -->
<section id="about" class="mb-5 py-4 bg-white rounded shadow-sm p-4">
    <div class="container">
        <h2 class="fw-bold mb-4">About Me</h2>
        <p class="mb-3">
            I am currently a third-year Bachelor of Science in Information Technology student. I have always been interested in how software and websites work, which led me to focus on programming and web development. Throughout my studies, I have learned to solve problems logically and work well both independently and in teams.
        </p>
        <p class="mb-3">
            My goal is to become a professional web developer and contribute to projects that help people and businesses. I plan to improve my skills in ASP.NET Core, databases, and front-end design. Outside of coding, I enjoy reading tech articles, playing games, and exploring new tools.
        </p>
        <div class="row mt-4">
            <div class="col-md-6">
                <h6 class="fw-semibold">Education</h6>
                <p>Bachelor of Science in Information Technology<br>Expected Graduation: 2027</p>
            </div>
            <div class="col-md-6">
                <h6 class="fw-semibold">Career Goal</h6>
                <p>To secure an internship and build production-ready applications.</p>
            </div>
        </div>
        <div class="mt-3">
            <a href="@Url.Action("Index", "About")" class="btn btn-primary">
                <i class="bi bi-arrow-right me-2"></i>Learn More About Me
            </a>
        </div>
    </div>
</section>

<!-- SKILLS SECTION -->
<section id="skills" class="mb-5 py-4">
    <div class="container">
        <h2 class="fw-bold mb-4">My Skills</h2>
        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body text-center">
                        <i class="bi bi-code-slash fs-2 text-primary mb-2"></i>
                        <h5 class="card-title">Languages</h5>
                        <p class="card-text">C#, Visual Basic, Java, Python, JavaScript</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body text-center">
                        <i class="bi bi-globe fs-2 text-primary mb-2"></i>
                        <h5 class="card-title">Web Tech</h5>
                        <p class="card-text">HTML5, CSS3, Bootstrap 5, ASP.NET MVC</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body text-center">
                        <i class="bi bi-database fs-2 text-primary mb-2"></i>
                        <h5 class="card-title">Databases</h5>
                        <p class="card-text">SQL Server, MySQL, MS Access, SQLite</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body text-center">
                        <i class="bi bi-pc-display fs-2 text-primary mb-2"></i>
                        <h5 class="card-title">Tools</h5>
                        <p class="card-text">Visual Studio, VB.NET, Git, GitHub</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="text-center mt-4">
            <a href="@Url.Action("Index", "Skills")" class="btn btn-primary">
                <i class="bi bi-arrow-right me-2"></i>View All Skills
            </a>
        </div>
    </div>
</section>

<!-- PROJECTS SECTION -->
<section id="projects" class="mb-5 py-4 bg-white rounded shadow-sm p-4">
    <div class="container">
        <h2 class="fw-bold mb-4">My Projects</h2>
        <div class="row g-4">
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow">
                    <img src="https://via.placeholder.com/400x200.png?text=CodeNect+POS+System" class="card-img-top" alt="CodeNect System Alliance POS System">
                    <div class="card-body">
                        <h5 class="card-title">CodeNect System Alliance - POS & Inventory System</h5>
                        <p class="card-text">Complete desktop Point of Sale and Inventory Management System with user accounts, sales tracking, product management, and vendor records.</p>
                        <p class="text-muted small"><strong>Tech:</strong> Visual Basic .NET, SQL Server</p>
                        <a href="https://github.com/mjudielmeguiel/CodeNect-System-Alliance.git" target="_blank" class="btn btn-primary w-100 mt-2">View on GitHub</a>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow">
                    <img src="https://via.placeholder.com/400x200.png?text=HttpClient+Project" class="card-img-top" alt="HttpClient Project">
                    <div class="card-body">
                        <h5 class="card-title">IT Elective 2 Prelim Exam - HttpClient</h5>
                        <p class="card-text">Complete ASP.NET Core project using HttpClient for API communication and data fetching.</p>
                        <p class="text-muted small"><strong>Tech:</strong> C#, ASP.NET MVC, HttpClient</p>
                        <a href="https://github.com/mjudielmeguiel/IT_ELECTIVE_2_PRELIM_EXAM.git" target="_blank" class="btn btn-primary w-100 mt-2">View on GitHub</a>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow">
                    <img src="https://via.placeholder.com/400x200.png?text=First+MVC+Application" class="card-img-top" alt="First MVC Application">
                    <div class="card-body">
                        <h5 class="card-title">First MVC Application</h5>
                        <p class="card-text">My first complete ASP.NET Core MVC web project with full project structure and layout setup.</p>
                        <p class="text-muted small"><strong>Tech:</strong> ASP.NET Core MVC, C#, HTML5, CSS3, Bootstrap</p>
                        <a href="https://github.com/mjudielmeguiel/First_MVC_Application.git" target="_blank" class="btn btn-primary w-100 mt-2">View on GitHub</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="text-center mt-4">
            <a href="@Url.Action("Index", "Projects")" class="btn btn-primary">
                <i class="bi bi-arrow-right me-2"></i>View All Projects
            </a>
        </div>
    </div>
</section>

<!-- CONTACT SECTION -->
<section id="contact" class="py-4">
    <div class="container">
        <h2 class="fw-bold mb-4">Contact Me</h2>
        <div class="card shadow-sm p-4">
            <div class="row g-3">
                <div class="col-md-6">
                    <p><i class="bi bi-envelope me-2 text-primary"></i>mjudielmeguiel@gmail.com</p>
                    <p><i class="bi bi-telephone me-2 text-primary"></i>09947388328</p>
                </div>
                <div class="col-md-6">
                    <p><i class="bi bi-github me-2 text-primary"></i><a href="https://github.com/mjudielmeguiel" target="_blank">github.com/mjudielmeguiel</a></p>
                    <p><i class="bi bi-linkedin me-2 text-primary"></i><a href="https://www.linkedin.com/in/judiel-meguiel-mescallado-0ba736382/?skipRedirect=true" target="_blank">Judiel Meguiel Mescallado</a></p>
                </div>
            </div>
            <div class="text-center mt-4">
                <a href="@Url.Action("Index", "Contact")" class="btn btn-primary">
                    <i class="bi bi-envelope me-2"></i>Send Me a Message
                </a>
            </div>
        </div>
    </div>
</section>

@model ProjectsViewModel

@{
    ViewData["Title"] = "My Projects";
}

<!-- PROJECTS SECTION -->
<section id="projects" class="mb-5 py-4 bg-white rounded shadow-sm p-4">
    <div class="container">
        <h2 class="fw-bold mb-4">My Projects</h2>
        <div class="row g-4">
            @foreach (var project in Model.Projects)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow">
                        <img src="@project.ImageUrl" class="card-img-top" alt="@project.Title">
                        <div class="card-body">
                            <h5 class="card-title">@project.Title</h5>
                            <p class="card-text">@project.Description</p>
                            <p class="text-muted small"><strong>Tech:</strong> @project.Technologies</p>
                            <a href="@project.GitHubUrl" target="_blank" class="btn btn-primary w-100 mt-2">View on GitHub</a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Navigation Buttons -->
        <div class="d-flex gap-2 mt-5">
            <a href="@Url.Action("Index", "Skills")" class="btn btn-outline-primary">
                <i class="bi bi-arrow-left me-2"></i>Back to Skills
            </a>
            <a href="@Url.Action("Index", "Contact")" class="btn btn-primary">
                <i class="bi bi-arrow-right me-2"></i>Contact Me
            </a>
        </div>
    </div>
</section>

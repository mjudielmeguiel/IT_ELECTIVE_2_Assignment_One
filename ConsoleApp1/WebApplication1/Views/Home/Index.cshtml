@{
    ViewData["Title"] = "Home";
}

<div class="text-center mt-5">
    <h1 class="display-4 fw-bold">@ViewData["FullName"]</h1>
    <h3 class="text-primary mb-3">@ViewData["Tagline"]</h3>
    <p class="lead mx-auto" style="max-width: 700px;">@ViewData["ShortIntro"]</p>
    <a asp-action="About" class="btn btn-dark btn-lg mt-4">Learn More About Me</a>
</div>
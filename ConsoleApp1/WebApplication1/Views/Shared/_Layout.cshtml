<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]?.ToString() ?? "Portfolio" | My Portfolio</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                font-family: Arial, sans-serif;
                min-height: 100vh;
                background-color: #f8f9fa;
            }

            /* Sidebar Style */
            .sidebar {
                background-color: #1a1a2e;
                width: 220px;
                position: fixed;
                top: 0;
                left: 0;
                height: 100vh;
                padding: 2rem 0;
            }

                .sidebar h4 {
                    color: #ffffff;
                    text-align: center;
                    margin-bottom: 2rem;
                    font-weight: 600;
                }

                .sidebar .nav-link {
                    color: #d1d1e9;
                    padding: 0.8rem 1.5rem;
                    display: flex;
                    align-items: center;
                    gap: 0.7rem;
                    transition: all 0.2s ease-in-out;
                    text-decoration: none;
                }

                    .sidebar .nav-link:hover,
                    .sidebar .nav-link.active {
                        background-color: #2d2d4f;
                        color: #ffffff;
                        border-left: 4px solid #0d6efd;
                    }

            /* Main Content Area */
            .main-content {
                margin-left: 220px;
                padding: 2.5rem;
                min-height: 100vh;
            }

            /* ✅ Responsive Design for Mobile/Tablet */
            @@media (max-width: 768px) {
                .sidebar {
                    width: 100%;
                    height: auto;
                    position: relative;
                }

                .main-content {
                    margin-left: 0;
                }
            }
    </style>
</head>
<body>
    <!-- Sidebar Navigation -->
    <div class="sidebar">
        <h4>My Portfolio</h4>
        <nav class="nav flex-column">
            <a class="nav-link @(ViewData["Title"]?.ToString() == "Home" ? "active" : "")" asp-action="Index">
                <i class="bi bi-house"></i> Home
            </a>
            <a class="nav-link @(ViewData["Title"]?.ToString() == "About Me" ? "active" : "")" asp-action="About">
                <i class="bi bi-person"></i> About Me
            </a>
            <a class="nav-link @(ViewData["Title"]?.ToString() == "Skills" ? "active" : "")" asp-action="Skills">
                <i class="bi bi-tools"></i> Skills
            </a>
            <a class="nav-link @(ViewData["Title"]?.ToString() == "Projects" ? "active" : "")" asp-action="Projects">
                <i class="bi bi-folder"></i> Projects
            </a>
            <a class="nav-link @(ViewData["Title"]?.ToString() == "Contact" ? "active" : "")" asp-action="Contact">
                <i class="bi bi-envelope"></i> Contact
            </a>
        </nav>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        @RenderBody()
    </div>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>